generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Book {
  id           String   @id @default(cuid())
  title        String
  author       String
  description  String?
  price        Decimal
  stock        Int      @default(0)
  imageUrl     String?
  isBestSeller Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
